nano $HOME/.config/nixos/nix/options.nix
echo 'Rebuilding NixOS...' && nix-shell -p git --run "sudo nixos-rebuild switch --flake $HOME/.config/nixos/nix --impure --quiet --cores=$(nproc) --max-jobs=$(nproc)" && echo Done!
