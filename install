#qemu.enable = false;
#streaming.enable = false;
#gui.enable = false;
#airdrop.enable = false;
#mpris.enable = false;
#entertainment.enable = false;
#drawing.enable = false;
#chat.enable = false;
#supersonic.enable = false;
#spinner.enable = false;
};
}
EOF
